# === LLM Provider API Keys ===
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
# Cerebras (optional, AE2 fallback)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# === Agent Ports ===
# Mapped to the UPC FIB VM tunnel (nattech.fib.upc.edu 40530-40539 → 8080-8089).
ORCHESTRATOR_PORT=8080
NORMALIZER_PORT=8081
AE1_PORT=8082
AE2_PORT=8083
FEEDBACK_PORT=8084
MCP_PORT=8085
FRONTEND_PORT=8086
AE3_PORT=8087

# === LLM Models ===
ORCHESTRATOR_MODEL=groq/llama-3.3-70b-versatile
NORMALIZER_MODEL=gemini/gemini-2.5-flash
AE1_MODEL=mistral/mistral-large-latest
AE2_MODEL=cerebras/qwen-3-235b-a22b-instruct-2507
AE3_MODEL=groq/llama-3.1-8b-instant
FEEDBACK_MODEL=ollama/qwen2.5:14b

# === Ollama (for feedback agent) ===
OLLAMA_API_BASE=http://localhost:11434

# === Debate Settings ===
MAX_DEBATE_ROUNDS=5

# === Deployment (only needed outside local dev) ===
# Hostname used by workers to reach the orchestrator. In Docker Compose this
# is set per-service to the orchestrator's service name. In local dev leave
# it as "localhost".
ORCHESTRATOR_HOST=localhost
# Hostname this process advertises to the registry. Each agent container in
# Compose sets this to its own service name (e.g. ae1, normalizer).
SELF_HOST=localhost
# Hostname specialized agents use to reach the MCP tools server. Local dev:
# localhost. Docker Compose: "mcp-tools" (Compose service name).
MCP_HOST=localhost
# CORS origins allowed to call the orchestrator. Comma-separated list.
# In VM production add http://nattech.fib.upc.edu:40536 (public frontend URL).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8086

# === Dynamic worker pool (sub-phase 2c) ===
WORKER_PORT_POOL_START=9010
WORKER_PORT_POOL_SIZE=20
