# === LLM Provider API Keys ===
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
# Cerebras (optional, AE2 fallback)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# === Agent Ports ===
ORCHESTRATOR_PORT=9000
NORMALIZER_PORT=9001
AE1_PORT=9002
AE2_PORT=9003
FEEDBACK_PORT=9004

# === LLM Models ===
ORCHESTRATOR_MODEL=groq/llama-3.3-70b-versatile
NORMALIZER_MODEL=gemini/gemini-2.5-flash
AE1_MODEL=mistral/mistral-large-latest
AE2_MODEL=cerebras/llama3.1-70b
FEEDBACK_MODEL=ollama/qwen2.5:14b

# === Ollama (for feedback agent) ===
OLLAMA_API_BASE=http://localhost:11434

# === Debate Settings ===
MAX_DEBATE_ROUNDS=5
