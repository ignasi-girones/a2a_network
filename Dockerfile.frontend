FROM node:22-alpine

WORKDIR /app

COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci

COPY frontend/ .

# Vite binds to 8086 inside the container (matches the VM external tunnel
# nattech.fib.upc.edu:40536 → 172.16.4.53:8086). Override with VITE_PORT.
ENV VITE_PORT=8086
EXPOSE 8086

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
